{
  "name": "istv-reel-editor",
  "productName": "ISTV Reel Editor",
  "version": "0.1.0",
  "description": "Cross-platform desktop editor that turns a documentary into 9:16 reels.",
  "main": "src/main/main.js",
  "author": "ISTV",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "node scripts/launch.js",
    "smoke": "node scripts/launch.js --smoke",
    "test": "node test/model.test.js",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "build": {
    "appId": "com.istv.reel-editor",
    "productName": "ISTV Reel Editor",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Inside-Success",
      "repo": "istv-reel-editor-backend",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
