# Copy this file to ".env" and fill in your keys. ".env" is gitignored — never commit it.

# Rev.ai API key — used for word-level transcription.
# Get one at https://www.rev.ai/access-token
REVAI_API_KEY=

# Anthropic (Claude) API key — used for transcript cleanup + reel selection.
# Get one at https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=
