.env
__pycache__/
*.pyc

# Virtual environment
.venv/

# Never commit large media outputs
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.m4v
*.zip

# Job bundles (transcripts, analysis, exports) stay local
generated_data/*/
!generated_data/.gitkeep

# Source videos stay local
input/*
!input/.gitkeep

# Local durable job registry (backend/job_store.py)
backend/jobs.db

# Local Claude Code runtime artifacts
.claude/

# Deployment (Vercel) + any .env variant
.vercel
.env*

# Desktop app build + deps
desktop/dist
desktop/node_modules
